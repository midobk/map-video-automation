APP_ENV=local
PROVIDER_MODE=mock
RENDER_MODE=local
PUBLISHER_MODE=mock
PUBLISHING_KILL_SWITCH=true
ALLOW_LOCAL_EXTERNAL_PUBLISHING=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase. For local dev, run `supabase start` and paste the values here.
# For Vercel preview/production, add these as Environment Variables attached to
# the Preview and Production environments (not exposed to the browser).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Add real provider credentials only in local secret stores or managed cloud settings.
# Never commit them.
OPENAI_API_KEY=
