APP_ENV=local
PROVIDER_MODE=mock
RENDER_MODE=local
PUBLISHER_MODE=mock
PUBLISHING_KILL_SWITCH=true
ALLOW_LOCAL_EXTERNAL_PUBLISHING=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase local project. Update these after running `supabase start` or `supabase status`.
