APP_ENV=local
PROVIDER_MODE=mock
RENDER_MODE=local
PUBLISHER_MODE=mock
PUBLISHING_KILL_SWITCH=true
ALLOW_LOCAL_EXTERNAL_PUBLISHING=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase. For local dev, run `supabase start` and paste the values here.
# For Vercel preview/production, add these as Environment Variables attached to
# the Preview and Production environments (not exposed to the browser).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI and TTS provider credentials. Leave empty to use deterministic mocks.
# Never commit real keys.
#
# Fastest MVP (real narrated videos via the /make page):
#   PROVIDER_MODE=openai       (or 'minimax' to use MiniMax M3 instead of OpenAI)
#   OPENAI_API_KEY=sk-...      (required when PROVIDER_MODE=openai)
#   MINIMAX_API_KEY=sk-...     (required when PROVIDER_MODE=minimax)
#   TTS_PROVIDER=elevenlabs
#   ELEVENLABS_API_KEY=...
#   ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # optional; defaults to this voice
# Rendering only works locally (RENDER_MODE=local); Remotion cannot run on
# Vercel serverless, so the deployed app produces plans, not MP4s.
OPENAI_API_KEY=
MINIMAX_API_KEY=
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Add other real provider credentials only in local secret stores or managed cloud settings.
