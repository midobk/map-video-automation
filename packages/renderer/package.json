{
  "name": "@mapvideo/renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./captions/split": {
      "types": "./src/captions/split.ts",
      "default": "./dist/captions/split.js"
    },
    "./captions/types": {
      "types": "./src/captions/types.ts",
      "default": "./dist/captions/types.js"
    },
    "./compositions/map-video/schema": {
      "types": "./src/compositions/map-video/map-video-schema.ts",
      "default": "./dist/compositions/map-video/map-video-schema.js"
    },
    "./themes/examples": {
      "types": "./src/themes/examples.ts",
      "default": "./dist/themes/examples.js"
    },
    "./voice": {
      "types": "./src/voice/index.ts",
      "default": "./dist/voice/index.js"
    },
    "./voice/server": {
      "types": "./src/voice/server.ts",
      "default": "./dist/voice/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/fix-esm-imports.mjs dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@remotion/google-fonts": "4.0.475",
    "d3-geo": "3.1.1",
    "remotion": "4.0.475",
    "topojson-client": "3.1.0",
    "world-atlas": "2.0.2",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/d3-geo": "3.1.0",
    "@types/geojson": "7946.0.16",
    "@types/react": "19.2.17",
    "@types/topojson-client": "3.1.5",
    "@types/topojson-specification": "1.0.5",
    "react": "19.2.7",
    "world-countries": "5.1.0"
  }
}
