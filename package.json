{
  "name": "map-video-automation",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.16.0 <23",
    "pnpm": ">=10.13.1 <11"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "bash scripts/verify-local.sh",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify && pnpm geo:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secrets:scan": "bash scripts/secret-scan.sh",
    "geo:prepare": "node --import tsx packages/renderer/scripts/prepare-geo-data.ts",
    "geo:check": "node --import tsx packages/renderer/scripts/prepare-geo-data.ts --check",
    "remotion:studio": "pnpm --filter @mapvideo/remotion-studio exec remotion studio",
    "remotion:render:fixture": "pnpm --filter @mapvideo/remotion-studio exec remotion render starter out/starter/starter.mp4",
    "remotion:frame:fixture": "pnpm --filter @mapvideo/remotion-studio exec remotion still starter out/starter/starter-frame.png --frame=60",
    "remotion:render:map-video": "pnpm --filter @mapvideo/remotion-studio exec remotion render map-video out/map-video/map-video.mp4",
    "remotion:render:rtl-fixture": "pnpm --filter @mapvideo/remotion-studio exec remotion render map-video-rtl out/map-video-rtl/map-video-rtl.mp4",
    "remotion:render:country-zoom": "pnpm --filter @mapvideo/remotion-studio exec remotion render map-video-country-zoom out/map-video-country-zoom/map-video-country-zoom.mp4",
    "remotion:render:ranking": "pnpm --filter @mapvideo/remotion-studio exec remotion render map-video-ranking out/map-video-ranking/map-video-ranking.mp4",
    "visual-regression": "bash scripts/visual-regression.sh",
    "sfx:generate": "node scripts/media/generate-sfx.mjs",
    "voiceover:generate": "node --import tsx scripts/media/generate-voiceover.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.15.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
