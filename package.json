{
  "name": "map-video-automation",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.16.0 <23",
    "pnpm": ">=10.13.1 <11"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "bash scripts/verify-local.sh",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secrets:scan": "bash scripts/secret-scan.sh"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
